{
  "expo": {
    "name": "PaintPro",
    "slug": "paintpro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "cli": {
      "appVersionSource": "remote"
    },

    "scheme": "paintpro",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icony.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A5F"
    },
    "expo-notifications": {
      "icon": "./assets/images/icon.png",
      "color": "#1E3A5F"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/paintpro_logo.png",
        "backgroundColor": "#1E3A5F"
      },
      "package": "com.kamesh.paintpro",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1E3A5F",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow PaintPro to access your photos to upload site photos.",
          "cameraPermission": "Allow PaintPro to use camera to take site photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4764ed86-2ae9-4b74-bafd-f90dbf60f6d5"
      }
    }
  }
}
